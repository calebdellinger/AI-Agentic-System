# Sovereign Dual-Hemisphere AI OS
#
# Rationale: Provider + OpenAI-compatible endpoints for AutoGen (RD-Lab).
# How: Copy to `.env`. Do not commit secrets.
#

# Primary semantic mode (LOCAL | GEMINI | ANTHROPIC). Default in code/compose is GEMINI for prototyping.
PROVIDER_MODE=GEMINI

# Gemini (Google AI Studio): required when PROVIDER_MODE=GEMINI — AutoGen uses OpenAI-compatible API.
# https://ai.google.dev/gemini-api/docs/openai
GOOGLE_API_KEY=change-me
GEMINI_OPENAI_BASE_URL=

# LOCAL / on-prem (set PROVIDER_MODE=LOCAL when your hardware is ready)
# Ollama / vLLM OpenAI-compatible base URL
VLLM_BASE_URL=http://vllm-server:8000/v1
MODEL_NAME=llama3.2:1b

# Local throttle (used when PROVIDER_MODE=LOCAL; model IDs depend on your runtime)
LOCAL_LIGHT_MODEL_NAME=llama3.2:1b
LOCAL_HEAVY_MODEL_NAME=llama3.2:3b

# When PROVIDER_MODE=LOCAL: set true only if your local model can sustain AutoGen GroupChat (larger models).
AUTOGEN_ENABLE_GROUPCHAT_LOCAL=false

# Optional: any OpenAI-compatible provider (overrides per-request routing)
AUTOGEN_OPENAI_BASE_URL=
AUTOGEN_OPENAI_API_KEY=

# When using remote OpenAI-compat (Gemini tier or PROVIDER_MODE=GEMINI), these defaults apply:
# Cloud AutoGen: 2.5 Flash family only (lite = light tier, flash = heavy tier).
CLOUD_LIGHT_MODEL_NAME=gemini-2.5-flash-lite
CLOUD_HEAVY_MODEL_NAME=gemini-2.5-flash

# Anthropic: no native OpenAI URL in-process; use LiteLLM proxy or set:
ANTHROPIC_OPENAI_COMPAT_BASE_URL=
ANTHROPIC_API_KEY=change-me

# Trinity fallback (separate from RD-Lab AutoGen routing)
FALLBACK_PROVIDER_MODE=GEMINI

# Shared company knowledge tree (mounted at COMPANY_KNOWLEDGE_ROOT in compose)
COMPANY_KNOWLEDGE_SLUG=example-regional-concrete

# n8n
N8N_WORKORDER_WEBHOOK_URL=http://n8n:5678/webhook/trinity-workorder
N8N_WORKORDER_WEBHOOK_SECRET=change-me
N8N_HOST=localhost
N8N_PORT=5678
WEBHOOK_URL=http://localhost:5678
N8N_ENCRYPTION_KEY=change-me

# Notion automation via n8n HTTP nodes
# Create an internal integration in Notion and paste the secret token.
NOTION_API_TOKEN=change-me
# Default Notion API version header for HTTP requests.
NOTION_API_VERSION=2022-06-28
# Optional fallback database ID for notion_create operation.
NOTION_DATABASE_ID=
