+# Sovereign Dual-Hemisphere AI OS
+#
+# Rationale: This file documents the minimum configuration contract for
+# provider selection, escalation, and external-world boundaries (n8n).
+#
+# How: Copy to `.env` and adjust values for your environment.
+#
+# Contracts:
+# - `PROVIDER_MODE` controls the primary model provider.
+# - `FALLBACK_PROVIDER_MODE` controls the escalation target after repeated
+#   local Pydantic validation failures.
+#
+# Sovereignty Notes: Do not store secrets in shared volumes; keep secrets in
+# environment variables on the host that launches the containers.
+
PROVIDER_MODE=LOCAL
FALLBACK_PROVIDER_MODE=GEMINI

# LOCAL (vLLM via OpenAI-compatible API)
VLLM_BASE_URL=http://vllm-server:8000/v1

# GEMINI (LangChain Google GenAI)
GOOGLE_API_KEY=change-me

# ANTHROPIC (LangChain Anthropic)
ANTHROPIC_API_KEY=change-me

# n8n webhook contract for Trinity work orders
N8N_WORKORDER_WEBHOOK_URL=http://n8n:5678/webhook/trinity-workorder
N8N_WORKORDER_WEBHOOK_SECRET=change-me

# n8n UI host wiring (optional)
N8N_HOST=localhost
N8N_PORT=5678
WEBHOOK_URL=http://localhost:5678
N8N_ENCRYPTION_KEY=change-me

