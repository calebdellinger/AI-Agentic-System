      "id": "webhook_in",
      "name": "Webhook In",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        -1040,
        300
      ]
    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const input = $input.first().json || {};\nconst expectedSecret = $env.N8N_WORKORDER_WEBHOOK_SECRET || '';\n\nconst headers = input.headers || {};\nconst headerSecret =\n  headers['x-workorder-secret'] ||\n  headers['X-WorkOrder-Secret'] ||\n  headers['x_workorder_secret'] ||\n  '';\n\nconst workOrder = input.work_order_id ? input : (input.body || input);\nconst required = ['work_order_id', 'correlation_id', 'operation', 'idempotency_key'];\nconst missing = required.filter((k) => !workOrder[k]);\n\nif (expectedSecret && headerSecret !== expectedSecret) {\n  return [{\n    json: {\n      route: 'rejected',\n      ok: false,\n      status: 'rejected',\n      reason: 'invalid_webhook_secret',\n      received_utc: new Date().toISOString()\n    }\n  }];\n}\n\nif (missing.length > 0) {\n  return [{\n    json: {\n      route: 'rejected',\n      ok: false,\n      status: 'rejected',\n      reason: 'missing_required_fields',\n      missing_fields: missing,\n      received_utc: new Date().toISOString()\n    }\n  }];\n}\n\nconst store = getWorkflowStaticData('global');\nif (!store.idempotencySeen) {\n  store.idempotencySeen = {};\n}\nconst seen = store.idempotencySeen;\nconst key = String(workOrder.idempotency_key);\n\nif (seen[key]) {\n  return [{\n    json: {\n      route: 'duplicate',\n      ok: true,\n      status: 'duplicate_ignored',\n      work_order_id: String(workOrder.work_order_id),\n      correlation_id: String(workOrder.correlation_id),\n      operation: String(workOrder.operation),\n      idempotency_key: key,\n      first_seen_utc: seen[key].first_seen_utc,\n      received_utc: new Date().toISOString()\n    }\n  }];\n}\n\nseen[key] = {\n  first_seen_utc: new Date().toISOString(),\n  work_order_id: String(workOrder.work_order_id),\n  operation: String(workOrder.operation)\n};\n\nreturn [{\n  json: {\n    route: String(workOrder.operation || 'unsupported'),\n    work_order: workOrder,\n    work_order_id: String(workOrder.work_order_id),\n    correlation_id: String(workOrder.correlation_id),\n    operation: String(workOrder.operation || 'unsupported'),\n    idempotency_key: key,\n    decision_dna_ref: workOrder.decision_dna_ref || null,\n    received_utc: new Date().toISOString()\n  }\n}];"
      },
      "id": "validate_and_route",
      "name": "Validate + Idempotency Guard",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -800,
        300
      ]
    },
    {
      "parameters": {
        "dataType": "string",
        "value1": "={{$json.route}}",
        "rules": [
          {
            "operation": "equal",
            "value2": "rejected"
          },
          {
            "operation": "equal",
            "value2": "duplicate"
