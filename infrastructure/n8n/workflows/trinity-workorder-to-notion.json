          {
            "operation": "equal",
            "value2": "notion_create"
          },
          {
            "operation": "equal",
            "value2": "notion_update"
          },
          {
            "operation": "equal",
            "value2": "noop"
          }
        ],
        "fallbackOutput": 6
      },
      "id": "route_switch",
      "name": "Route by Operation",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 1,
      "position": [
        -560,
        300
      ]
    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const p = $json.work_order?.payload || {};\nconst databaseId = p.database_id || $env.NOTION_DATABASE_ID || '';\nif (!databaseId) {\n  throw new Error('Missing database_id in payload and NOTION_DATABASE_ID env var.');\n}\n\nconst properties = p.properties || {};\nconst children = Array.isArray(p.children) ? p.children : [];\n\nreturn [{\n  json: {\n    ...$json,\n    notion_request_body: {\n      parent: { database_id: databaseId },\n      properties,\n      children\n    }\n  }\n}];"
      },
      "id": "prepare_notion_create",
      "name": "Prepare Notion Create Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -320,
        420
      ]
    },
    {
      "parameters": {
        "url": "https://api.notion.com/v1/pages",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.NOTION_API_TOKEN}}"
            },
            {
              "name": "Notion-Version",
              "value": "={{$env.NOTION_API_VERSION || '2022-06-28'}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{$json.notion_request_body}}"
      },
      "id": "notion_create_http",
      "name": "Notion Create Page",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -80,
        420
      ]
    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const response = $input.first().json || {};\nconst work = $('Prepare Notion Create Request').first().json;\n\nreturn [{\n  json: {\n    ok: true,\n    status: 'completed',\n    operation: work.operation,\n    work_order_id: work.work_order_id,\n    correlation_id: work.correlation_id,\n    idempotency_key: work.idempotency_key,\n    decision_dna_ref: work.decision_dna_ref,\n    received_utc: work.received_utc,\n    completed_utc: new Date().toISOString(),\n    notion: {\n      action: 'create_page',\n      page_id: response.id || null,\n      url: response.url || null\n    }\n  }\n}];"
      },
      "id": "format_notion_create_result",
      "name": "Format Notion Create Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        160,
        420
      ]
    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const p = $json.work_order?.payload || {};\nconst pageId = p.page_id || '';\nif (!pageId) {\n  throw new Error('Missing payload.page_id for notion_update operation.');\n}\n\nconst body = {};\nif (p.properties && typeof p.properties === 'object') body.properties = p.properties;\nif (typeof p.archived === 'boolean') body.archived = p.archived;\nif (p.icon) body.icon = p.icon;\nif (p.cover) body.cover = p.cover;\n\nreturn [{\n  json: {\n    ...$json,\n    notion_page_id: pageId,\n    notion_request_body: body\n  }\n}];"
      },
